{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "experiment.schema.json",
  "title": "Agent Harness Test ExperimentSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "title",
    "description",
    "mode",
    "suite",
    "repetitions",
    "ordering",
    "configurations",
    "reporting"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/semver"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "smoke",
        "benchmark"
      ]
    },
    "suite": {
      "$ref": "common.schema.json#/$defs/suiteReference"
    },
    "task_selection": {
      "$ref": "#/$defs/taskSelection"
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1
    },
    "ordering": {
      "$ref": "#/$defs/ordering"
    },
    "configurations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/agentConfiguration"
      }
    },
    "reporting": {
      "$ref": "#/$defs/reporting"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "benchmark"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "repetitions": {
            "type": "integer",
            "minimum": 5
          },
          "ordering": {
            "type": "object",
            "properties": {
              "mode": {
                "const": "randomized"
              },
              "seed": true
            },
            "required": [
              "seed"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "taskSelection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "exclude": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        }
      },
      "oneOf": [
        {
          "properties": {
            "include": true
          },
          "required": [
            "include"
          ]
        },
        {
          "properties": {
            "exclude": true
          },
          "required": [
            "exclude"
          ]
        }
      ]
    },
    "ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "listed",
            "randomized"
          ]
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "randomized"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "type": "object",
            "properties": {
              "seed": true
            },
            "required": [
              "seed"
            ]
          }
        }
      ]
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cuts",
        "comparisons"
      ],
      "properties": {
        "cuts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "configuration",
              "harness",
              "model",
              "effort",
              "observed-at",
              "task",
              "category",
              "language"
            ]
          }
        },
        "comparisons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/comparison"
          }
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "baseline_configuration_id",
        "candidate_configuration_ids",
        "gates"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "baseline_configuration_id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "candidate_configuration_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate"
          }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "operator",
        "threshold",
        "scope"
      ],
      "properties": {
        "metric": {
          "enum": [
            "headline-score",
            "headline-score-delta",
            "pass-rate",
            "pass-rate-delta",
            "operational-error-rate",
            "task-score-delta"
          ]
        },
        "operator": {
          "enum": [
            ">=",
            ">",
            "<=",
            "<"
          ]
        },
        "threshold": {
          "type": "number"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "informational": {
          "type": "boolean"
        }
      }
    }
  }
}
