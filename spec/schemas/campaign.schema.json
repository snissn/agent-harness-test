{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campaign.schema.json",
  "title": "Agent Harness Test finalized campaign record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "experiment",
    "suite",
    "mode",
    "observed_at",
    "started_at",
    "finished_at",
    "status",
    "runner",
    "preflight",
    "planned_run_count",
    "runs",
    "summary",
    "labels",
    "errors",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment": {
      "$ref": "#/$defs/experimentReference"
    },
    "suite": {
      "$ref": "common.schema.json#/$defs/suiteReference"
    },
    "mode": {
      "enum": [
        "smoke",
        "benchmark"
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "cancelled",
        "failed"
      ]
    },
    "runner": {
      "$ref": "#/$defs/runner"
    },
    "preflight": {
      "$ref": "#/$defs/preflight"
    },
    "planned_run_count": {
      "type": "integer",
      "minimum": 1
    },
    "runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runReference"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/errorRecord"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "preflight": {
            "type": "object",
            "properties": {
              "harness_runtimes": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "experimentReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "git_commit",
        "runtime"
      ],
      "properties": {
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "runtime": {
          "$ref": "common.schema.json#/$defs/runnerRuntime"
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "finished_at",
        "harness_runtimes"
      ],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "harness_runtimes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/harnessRuntimeResolution"
          }
        }
      }
    },
    "harnessRuntimeResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness_family",
        "runtime_source",
        "requested_runtime",
        "resolved_runtime_version",
        "runtime_digest",
        "executable_digest",
        "acquisition"
      ],
      "properties": {
        "harness_family": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "runtime_source": {
          "type": "string",
          "minLength": 1
        },
        "requested_runtime": {
          "type": "string",
          "minLength": 1
        },
        "resolved_runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "runtime_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "executable_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "acquisition": {
          "enum": [
            "preinstalled",
            "cache-hit",
            "installed"
          ]
        }
      }
    },
    "runReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "path",
        "digest"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recorded_runs",
        "operational_successes",
        "quality_eligible_runs",
        "end_to_end_passes",
        "invalid_runs"
      ],
      "properties": {
        "recorded_runs": {
          "type": "integer",
          "minimum": 0
        },
        "operational_successes": {
          "type": "integer",
          "minimum": 0
        },
        "quality_eligible_runs": {
          "type": "integer",
          "minimum": 0
        },
        "end_to_end_passes": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_runs": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
