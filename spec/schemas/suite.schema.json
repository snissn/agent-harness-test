{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Harness Test SuiteSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "status",
    "title",
    "description",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/semver"
    },
    "status": {
      "enum": [
        "draft",
        "released",
        "retired"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/suiteTask"
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "released",
              "retired"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "spec_digest": true
              },
              "required": [
                "spec_digest"
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "suiteTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "weight",
        "anchor"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "anchor": {
          "type": "boolean"
        }
      }
    }
  }
}
