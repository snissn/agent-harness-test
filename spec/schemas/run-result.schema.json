{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Harness Test RunResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "campaign_id",
    "experiment",
    "suite",
    "task",
    "configuration_id",
    "repetition",
    "schedule_index",
    "observed_at",
    "started_at",
    "finished_at",
    "terminal",
    "resolved_configuration",
    "provenance",
    "metrics",
    "evaluation",
    "artifacts",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment": {
      "$ref": "#/$defs/experimentReference"
    },
    "suite": {
      "$ref": "common.schema.json#/$defs/suiteReference"
    },
    "task": {
      "$ref": "#/$defs/runTaskReference"
    },
    "configuration_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "repetition": {
      "type": "integer",
      "minimum": 1
    },
    "schedule_index": {
      "type": "integer",
      "minimum": 0
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminal": {
      "$ref": "#/$defs/terminal"
    },
    "resolved_configuration": {
      "$ref": "#/$defs/resolvedConfiguration"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluationSummary"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/artifact"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "$defs": {
    "experimentReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "runTaskReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest",
        "prompt_digest",
        "initial_tree_digest",
        "evaluator_digest"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "prompt_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "initial_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        },
        "evaluator_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "attribution",
        "operational_success"
      ],
      "properties": {
        "reason": {
          "enum": [
            "agent_completed",
            "wall_time_exhausted",
            "token_limit_exhausted",
            "tool_limit_exhausted",
            "agent_failed",
            "provider_error",
            "harness_error",
            "environment_error",
            "cancelled"
          ]
        },
        "attribution": {
          "enum": [
            "agent",
            "provider",
            "harness",
            "benchmark",
            "operator"
          ]
        },
        "operational_success": {
          "type": "boolean"
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    },
    "resolvedModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "requested_id",
        "snapshot_available"
      ],
      "properties": {
        "provider": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "requested_id": {
          "type": "string",
          "minLength": 1
        },
        "resolved_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_available": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "snapshot_available": {
                "const": true
              }
            },
            "required": [
              "snapshot_available"
            ]
          },
          "then": {
            "properties": {
              "resolved_id": true
            },
            "required": [
              "resolved_id"
            ]
          }
        }
      ]
    },
    "resolvedConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness",
        "model",
        "effort",
        "limits",
        "effective_config_digest"
      ],
      "properties": {
        "harness": {
          "$ref": "common.schema.json#/$defs/harness"
        },
        "model": {
          "$ref": "#/$defs/resolvedModel"
        },
        "effort": {
          "$ref": "common.schema.json#/$defs/effort"
        },
        "limits": {
          "$ref": "common.schema.json#/$defs/limits"
        },
        "effective_config_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner_version",
        "runner_git_commit",
        "request_digest",
        "canonical_environment",
        "host_platform",
        "execution_environment_digest",
        "post_setup_tree_digest",
        "final_tree_digest"
      ],
      "properties": {
        "runner_version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "runner_git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "request_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "canonical_environment": {
          "type": "boolean"
        },
        "host_platform": {
          "type": "string",
          "minLength": 1
        },
        "execution_environment_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "post_setup_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        },
        "final_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "integer",
          "minimum": 0
        },
        "cached_input": {
          "type": "integer",
          "minimum": 0
        },
        "output": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_output": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_ms"
      ],
      "properties": {
        "wall_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "agent_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "evaluator_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "tokens": {
          "$ref": "#/$defs/tokenUsage"
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amount",
            "currency",
            "source"
          ],
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "scoredCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "score",
        "passed",
        "weight",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "passed": {
          "type": "boolean"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "evaluationSummary": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "result_artifact_digest",
            "checks",
            "artifact_quality_score",
            "criteria_passed",
            "agent_completion_required",
            "end_to_end_passed",
            "eligible_for_quality_aggregate"
          ],
          "properties": {
            "status": {
              "const": "ok"
            },
            "result_artifact_digest": {
              "$ref": "common.schema.json#/$defs/sha256"
            },
            "checks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/scoredCheck"
              }
            },
            "artifact_quality_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "criteria_passed": {
              "type": "boolean"
            },
            "agent_completion_required": {
              "type": "boolean"
            },
            "end_to_end_passed": {
              "type": "boolean"
            },
            "eligible_for_quality_aggregate": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason",
            "eligible_for_quality_aggregate"
          ],
          "properties": {
            "status": {
              "enum": [
                "error",
                "not-run"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "eligible_for_quality_aggregate": {
              "const": false
            }
          }
        }
      ]
    }
  }
}
