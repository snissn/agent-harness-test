{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-result.schema.json",
  "title": "Agent Harness Test RunResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "campaign_id",
    "experiment",
    "suite",
    "task",
    "configuration_id",
    "repetition",
    "schedule_index",
    "attempt",
    "observed_at",
    "started_at",
    "finished_at",
    "terminal",
    "resolved_configuration",
    "provenance",
    "metrics",
    "evaluation",
    "errors",
    "artifacts",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment": {
      "$ref": "#/$defs/experimentReference"
    },
    "suite": {
      "$ref": "common.schema.json#/$defs/suiteReference"
    },
    "task": {
      "$ref": "#/$defs/runTaskReference"
    },
    "configuration_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "repetition": {
      "type": "integer",
      "minimum": 1
    },
    "schedule_index": {
      "type": "integer",
      "minimum": 0
    },
    "attempt": {
      "$ref": "common.schema.json#/$defs/attempt"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminal": {
      "$ref": "#/$defs/terminal"
    },
    "resolved_configuration": {
      "$ref": "#/$defs/resolvedConfiguration"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluationSummary"
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/errorRecord"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/artifact"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "$defs": {
    "experimentReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "runTaskReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest",
        "prompt_digest",
        "initial_tree_digest",
        "evaluator_digest"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "spec_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "prompt_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "initial_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        },
        "evaluator_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "attribution",
        "operational_success"
      ],
      "properties": {
        "reason": {
          "enum": [
            "agent_completed",
            "wall_time_exhausted",
            "token_limit_exhausted",
            "tool_limit_exhausted",
            "agent_failed",
            "provider_error",
            "harness_error",
            "environment_error",
            "runner_error",
            "cancelled"
          ]
        },
        "attribution": {
          "enum": [
            "agent",
            "provider",
            "harness",
            "environment",
            "runner",
            "operator"
          ]
        },
        "operational_success": {
          "type": "boolean"
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "signal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resolvedModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "requested_id",
        "snapshot_available"
      ],
      "properties": {
        "provider": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "requested_id": {
          "type": "string",
          "minLength": 1
        },
        "resolved_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_available": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "snapshot_available": {
                "const": true
              }
            },
            "required": [
              "snapshot_available"
            ]
          },
          "then": {
            "properties": {
              "resolved_id": true
            },
            "required": [
              "resolved_id"
            ]
          }
        }
      ]
    },
    "resolvedConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness",
        "model",
        "effort",
        "limits",
        "effective_config_digest"
      ],
      "properties": {
        "harness": {
          "$ref": "common.schema.json#/$defs/harness"
        },
        "model": {
          "$ref": "#/$defs/resolvedModel"
        },
        "effort": {
          "$ref": "common.schema.json#/$defs/effort"
        },
        "limits": {
          "$ref": "common.schema.json#/$defs/limits"
        },
        "effective_config_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner_version",
        "runner_git_commit",
        "runner_runtime",
        "request_digest",
        "host",
        "execution",
        "post_setup_tree_digest",
        "final_tree_digest"
      ],
      "properties": {
        "runner_version": {
          "$ref": "common.schema.json#/$defs/semver"
        },
        "runner_git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "runner_runtime": {
          "$ref": "common.schema.json#/$defs/runnerRuntime"
        },
        "request_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "host": {
          "$ref": "common.schema.json#/$defs/hostFingerprint"
        },
        "execution": {
          "$ref": "common.schema.json#/$defs/executionTopology"
        },
        "post_setup_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        },
        "final_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "timingMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clock_source",
        "wall_time_ms",
        "phases_ms"
      ],
      "properties": {
        "clock_source": {
          "const": "monotonic"
        },
        "wall_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "phases_ms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "materialization": {
              "type": "integer",
              "minimum": 0
            },
            "setup": {
              "type": "integer",
              "minimum": 0
            },
            "harness_startup": {
              "type": "integer",
              "minimum": 0
            },
            "agent": {
              "type": "integer",
              "minimum": 0
            },
            "evaluation": {
              "type": "integer",
              "minimum": 0
            },
            "snapshot": {
              "type": "integer",
              "minimum": 0
            },
            "finalization": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "time_to_first_harness_event_ms": {
          "type": "integer",
          "minimum": 0
        },
        "time_to_first_agent_output_ms": {
          "type": "integer",
          "minimum": 0
        },
        "time_to_first_tool_call_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source"
      ],
      "properties": {
        "status": {
          "enum": [
            "complete",
            "partial",
            "unavailable"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "unavailable_reason": {
          "type": "string",
          "minLength": 1
        },
        "partial_reason": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "integer",
          "minimum": 0
        },
        "cached_input": {
          "type": "integer",
          "minimum": 0
        },
        "output": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_output": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "complete"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": false,
              "input": true,
              "output": true,
              "total": true
            },
            "required": [
              "input",
              "output",
              "total"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "partial"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": true
            },
            "required": [
              "partial_reason"
            ],
            "anyOf": [
              {
                "properties": {
                  "input": true
                },
                "required": [
                  "input"
                ]
              },
              {
                "properties": {
                  "output": true
                },
                "required": [
                  "output"
                ]
              },
              {
                "properties": {
                  "total": true
                },
                "required": [
                  "total"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unavailable"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "partial_reason": false,
              "input": false,
              "cached_input": false,
              "output": false,
              "reasoning_output": false,
              "total": false,
              "unavailable_reason": true
            },
            "required": [
              "unavailable_reason"
            ]
          }
        }
      ]
    },
    "toolUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source"
      ],
      "properties": {
        "status": {
          "enum": [
            "complete",
            "partial",
            "unavailable"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "unavailable_reason": {
          "type": "string",
          "minLength": 1
        },
        "partial_reason": {
          "type": "string",
          "minLength": 1
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "complete"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": false,
              "total": true,
              "failed": true
            },
            "required": [
              "total",
              "failed"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "partial"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": true
            },
            "required": [
              "partial_reason"
            ],
            "anyOf": [
              {
                "properties": {
                  "total": true
                },
                "required": [
                  "total"
                ]
              },
              {
                "properties": {
                  "failed": true
                },
                "required": [
                  "failed"
                ]
              },
              {
                "properties": {
                  "by_type": true
                },
                "required": [
                  "by_type"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unavailable"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "partial_reason": false,
              "total": false,
              "failed": false,
              "by_type": false,
              "unavailable_reason": true
            },
            "required": [
              "unavailable_reason"
            ]
          }
        }
      ]
    },
    "costMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source"
      ],
      "properties": {
        "status": {
          "enum": [
            "complete",
            "partial",
            "unavailable"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "unavailable_reason": {
          "type": "string",
          "minLength": 1
        },
        "partial_reason": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "complete"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": false,
              "amount": true,
              "currency": true
            },
            "required": [
              "amount",
              "currency"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "partial"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": true,
              "amount": true,
              "currency": true
            },
            "required": [
              "partial_reason",
              "amount",
              "currency"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unavailable"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "partial_reason": false,
              "amount": false,
              "currency": false,
              "unavailable_reason": true
            },
            "required": [
              "unavailable_reason"
            ]
          }
        }
      ]
    },
    "resourceUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source"
      ],
      "properties": {
        "status": {
          "enum": [
            "complete",
            "partial",
            "unavailable"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "unavailable_reason": {
          "type": "string",
          "minLength": 1
        },
        "partial_reason": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "agent-process",
            "process-tree",
            "container",
            "virtual-machine"
          ]
        },
        "cpu_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "peak_rss_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "filesystem_read_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "filesystem_written_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "network_received_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "network_sent_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_initial_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_final_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_delta_bytes": {
          "type": "integer"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "complete"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "partial_reason": false,
              "scope": true
            },
            "required": [
              "scope"
            ],
            "anyOf": [
              {
                "properties": {
                  "cpu_time_ms": true
                },
                "required": [
                  "cpu_time_ms"
                ]
              },
              {
                "properties": {
                  "peak_rss_bytes": true
                },
                "required": [
                  "peak_rss_bytes"
                ]
              },
              {
                "properties": {
                  "filesystem_read_bytes": true
                },
                "required": [
                  "filesystem_read_bytes"
                ]
              },
              {
                "properties": {
                  "filesystem_written_bytes": true
                },
                "required": [
                  "filesystem_written_bytes"
                ]
              },
              {
                "properties": {
                  "network_received_bytes": true
                },
                "required": [
                  "network_received_bytes"
                ]
              },
              {
                "properties": {
                  "network_sent_bytes": true
                },
                "required": [
                  "network_sent_bytes"
                ]
              },
              {
                "properties": {
                  "workspace_initial_bytes": true
                },
                "required": [
                  "workspace_initial_bytes"
                ]
              },
              {
                "properties": {
                  "workspace_final_bytes": true
                },
                "required": [
                  "workspace_final_bytes"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "partial"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "unavailable_reason": false,
              "scope": true,
              "partial_reason": true
            },
            "required": [
              "scope",
              "partial_reason"
            ],
            "anyOf": [
              {
                "properties": {
                  "cpu_time_ms": true
                },
                "required": [
                  "cpu_time_ms"
                ]
              },
              {
                "properties": {
                  "peak_rss_bytes": true
                },
                "required": [
                  "peak_rss_bytes"
                ]
              },
              {
                "properties": {
                  "filesystem_read_bytes": true
                },
                "required": [
                  "filesystem_read_bytes"
                ]
              },
              {
                "properties": {
                  "filesystem_written_bytes": true
                },
                "required": [
                  "filesystem_written_bytes"
                ]
              },
              {
                "properties": {
                  "network_received_bytes": true
                },
                "required": [
                  "network_received_bytes"
                ]
              },
              {
                "properties": {
                  "network_sent_bytes": true
                },
                "required": [
                  "network_sent_bytes"
                ]
              },
              {
                "properties": {
                  "workspace_initial_bytes": true
                },
                "required": [
                  "workspace_initial_bytes"
                ]
              },
              {
                "properties": {
                  "workspace_final_bytes": true
                },
                "required": [
                  "workspace_final_bytes"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unavailable"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "partial_reason": false,
              "scope": false,
              "cpu_time_ms": false,
              "peak_rss_bytes": false,
              "filesystem_read_bytes": false,
              "filesystem_written_bytes": false,
              "network_received_bytes": false,
              "network_sent_bytes": false,
              "workspace_initial_bytes": false,
              "workspace_final_bytes": false,
              "workspace_delta_bytes": false,
              "unavailable_reason": true
            },
            "required": [
              "unavailable_reason"
            ]
          }
        }
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timing",
        "tokens",
        "tool_usage",
        "cost",
        "resources"
      ],
      "properties": {
        "timing": {
          "$ref": "#/$defs/timingMetrics"
        },
        "tokens": {
          "$ref": "#/$defs/tokenUsage"
        },
        "tool_usage": {
          "$ref": "#/$defs/toolUsage"
        },
        "cost": {
          "$ref": "#/$defs/costMetric"
        },
        "resources": {
          "$ref": "#/$defs/resourceUsage"
        }
      }
    },
    "scoredCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "score",
        "passed",
        "weight",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "passed": {
          "type": "boolean"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "evaluationSummary": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "result_artifact_digest",
            "checks",
            "artifact_quality_score",
            "criteria_passed",
            "agent_completion_required",
            "end_to_end_passed",
            "eligible_for_quality_aggregate"
          ],
          "properties": {
            "status": {
              "const": "ok"
            },
            "result_artifact_digest": {
              "$ref": "common.schema.json#/$defs/sha256"
            },
            "checks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/scoredCheck"
              }
            },
            "artifact_quality_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "criteria_passed": {
              "type": "boolean"
            },
            "agent_completion_required": {
              "type": "boolean"
            },
            "end_to_end_passed": {
              "type": "boolean"
            },
            "eligible_for_quality_aggregate": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason",
            "eligible_for_quality_aggregate"
          ],
          "properties": {
            "status": {
              "enum": [
                "error",
                "not-run"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "eligible_for_quality_aggregate": {
              "const": false
            }
          }
        }
      ]
    }
  }
}
