{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Harness Test evaluator output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "task_version",
    "status",
    "started_at",
    "finished_at",
    "duration_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_version": {
      "$ref": "common.schema.json#/$defs/semver"
    },
    "status": {
      "enum": [
        "ok",
        "error"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkResult"
      }
    },
    "error_message": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "checks": true
        },
        "required": [
          "checks"
        ]
      },
      "else": {
        "properties": {
          "error_message": true
        },
        "required": [
          "error_message"
        ]
      }
    }
  ],
  "$defs": {
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "score",
        "passed"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "passed": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
