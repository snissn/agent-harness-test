{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "Agent Harness Test common definitions",
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "treeDigest": {
      "type": "string",
      "pattern": "^tree-sha256-v1:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "hardLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "enforcement"
      ],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1
        },
        "enforcement": {
          "const": "hard"
        }
      }
    },
    "optionalLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "enforcement"
      ],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1
        },
        "enforcement": {
          "enum": [
            "hard",
            "soft",
            "observe-only"
          ]
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_seconds"
      ],
      "properties": {
        "wall_time_seconds": {
          "$ref": "#/$defs/hardLimit"
        },
        "total_tokens": {
          "$ref": "#/$defs/optionalLimit"
        },
        "tool_calls": {
          "$ref": "#/$defs/optionalLimit"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "enabled",
            "disabled",
            "restricted"
          ]
        },
        "allow_domains": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allow_methods": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "GET",
              "HEAD",
              "OPTIONS",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "restricted"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "type": "object",
            "properties": {
              "allow_domains": true,
              "allow_methods": true
            },
            "required": [
              "allow_domains",
              "allow_methods"
            ]
          }
        }
      ]
    },
    "taskReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "spec_path": {
          "$ref": "#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "suiteReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "spec_path",
        "spec_digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "spec_path": {
          "$ref": "#/$defs/relativePath"
        },
        "spec_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "harness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "interface",
        "adapter_id",
        "adapter_version",
        "runtime_version",
        "config"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/identifier"
        },
        "interface": {
          "$ref": "#/$defs/identifier"
        },
        "adapter_id": {
          "$ref": "#/$defs/identifier"
        },
        "adapter_version": {
          "$ref": "#/$defs/semver"
        },
        "runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "requested_id"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/identifier"
        },
        "requested_id": {
          "type": "string",
          "minLength": 1
        },
        "expected_snapshot_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "effort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_label",
        "native_value"
      ],
      "properties": {
        "display_label": {
          "type": "string",
          "minLength": 1
        },
        "native_value": true
      }
    },
    "agentConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "harness",
        "model",
        "effort",
        "limits"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "harness": {
          "$ref": "#/$defs/harness"
        },
        "model": {
          "$ref": "#/$defs/model"
        },
        "effort": {
          "$ref": "#/$defs/effort"
        },
        "limits": {
          "$ref": "#/$defs/limits"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "digest"
      ],
      "properties": {
        "kind": {
          "enum": [
            "request",
            "run-result",
            "native-events",
            "normalized-events",
            "stdout",
            "stderr",
            "final-message",
            "workspace-patch",
            "workspace-tree",
            "evaluator-result",
            "other"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "mode",
        "initiated_by"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "enum": [
            "initial",
            "retry",
            "resume"
          ]
        },
        "initiated_by": {
          "enum": [
            "runner",
            "operator"
          ]
        },
        "parent_run_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "initial"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "number": {
                "const": 1
              },
              "parent_run_id": false
            }
          },
          "else": {
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 2
              },
              "parent_run_id": true,
              "reason": true
            },
            "required": [
              "parent_run_id",
              "reason"
            ]
          }
        }
      ]
    },
    "executionTopology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "isolation",
        "canonical",
        "credential_protection",
        "environment_digest",
        "operating_system",
        "architecture"
      ],
      "properties": {
        "mode": {
          "enum": [
            "host",
            "container",
            "virtual-machine"
          ]
        },
        "isolation": {
          "enum": [
            "none",
            "harness-sandbox",
            "outer-sandbox",
            "combined"
          ]
        },
        "canonical": {
          "type": "boolean"
        },
        "credential_protection": {
          "enum": [
            "harness-sandbox",
            "brokered",
            "short-lived",
            "unprotected"
          ]
        },
        "environment_digest": {
          "$ref": "#/$defs/sha256"
        },
        "operating_system": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "string",
          "minLength": 1
        },
        "runtime_name": {
          "type": "string",
          "minLength": 1
        },
        "runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "image_digest": {
          "$ref": "#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "canonical": {
                "const": true
              }
            },
            "required": [
              "canonical"
            ]
          },
          "then": {
            "properties": {
              "mode": {
                "enum": [
                  "container",
                  "virtual-machine"
                ]
              },
              "isolation": {
                "enum": [
                  "outer-sandbox",
                  "combined"
                ]
              },
              "credential_protection": {
                "enum": [
                  "harness-sandbox",
                  "brokered",
                  "short-lived"
                ]
              },
              "runtime_name": true,
              "runtime_version": true,
              "image_digest": true
            },
            "required": [
              "runtime_name",
              "runtime_version",
              "image_digest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "host"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "isolation": {
                "const": "harness-sandbox"
              },
              "canonical": {
                "const": false
              },
              "credential_protection": {
                "enum": [
                  "harness-sandbox",
                  "brokered",
                  "short-lived"
                ]
              }
            }
          }
        }
      ]
    },
    "sanitizedEnvironmentEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "classification",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z_][A-Z0-9_]*$"
        },
        "classification": {
          "enum": [
            "public",
            "redacted",
            "unset"
          ]
        },
        "source": {
          "enum": [
            "runner",
            "task",
            "harness",
            "secret-store",
            "host"
          ]
        },
        "value": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": {
                "const": "public"
              }
            },
            "required": [
              "classification"
            ]
          },
          "then": {
            "properties": {
              "value": true
            },
            "required": [
              "value"
            ]
          },
          "else": {
            "properties": {
              "value": false
            }
          }
        }
      ]
    },
    "hostFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operating_system",
        "architecture"
      ],
      "properties": {
        "operating_system": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "string",
          "minLength": 1
        },
        "kernel": {
          "type": "string",
          "minLength": 1
        },
        "cpu_model": {
          "type": "string",
          "minLength": 1
        },
        "logical_processor_count": {
          "type": "integer",
          "minimum": 1
        },
        "total_memory_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "locale": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runnerRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "errorRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "occurred_at",
        "phase",
        "code",
        "attribution",
        "retryable",
        "message"
      ],
      "properties": {
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "phase": {
          "enum": [
            "campaign-preflight",
            "resolution",
            "request-finalization",
            "materialization",
            "setup",
            "harness-startup",
            "agent",
            "snapshot",
            "evaluation",
            "finalization",
            "indexing",
            "reporting",
            "operator"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "attribution": {
          "enum": [
            "agent",
            "provider",
            "harness",
            "environment",
            "evaluator",
            "runner",
            "operator"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "cause_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "external_request_id": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "artifact_path": {
          "$ref": "#/$defs/relativePath"
        },
        "artifact_digest": {
          "$ref": "#/$defs/sha256"
        },
        "details": {
          "$ref": "#/$defs/extensions"
        }
      },
      "dependentRequired": {
        "artifact_path": [
          "artifact_digest"
        ],
        "artifact_digest": [
          "artifact_path"
        ]
      }
    }
  }
}
