{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Harness Test TaskSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "status",
    "title",
    "summary",
    "category",
    "tags",
    "languages",
    "prompt",
    "problem_state",
    "environment",
    "evaluator",
    "scoring",
    "default_limits"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/semver"
    },
    "status": {
      "enum": [
        "draft",
        "candidate",
        "released",
        "retired"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "enum": [
        "build",
        "bugfix",
        "feature",
        "tests",
        "integration",
        "concurrency",
        "refactor",
        "repair"
      ]
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "common.schema.json#/$defs/identifier"
      }
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prompt": {
      "$ref": "#/$defs/prompt"
    },
    "problem_state": {
      "$ref": "#/$defs/problemState"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "evaluator": {
      "$ref": "#/$defs/evaluator"
    },
    "scoring": {
      "$ref": "#/$defs/scoring"
    },
    "default_limits": {
      "$ref": "common.schema.json#/$defs/limits"
    },
    "calibration": {
      "$ref": "#/$defs/calibration"
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "candidate",
              "released",
              "retired"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "prompt": {
            "type": "object",
            "properties": {
              "digest": true
            },
            "required": [
              "digest"
            ]
          },
          "problem_state": {
            "type": "object",
            "properties": {
              "expected_tree_digest": true
            },
            "required": [
              "expected_tree_digest"
            ]
          },
          "evaluator": {
            "type": "object",
            "properties": {
              "digest": true
            },
            "required": [
              "digest"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "released",
              "retired"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "calibration": true
        },
        "required": [
          "calibration"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "candidate",
              "released",
              "retired"
            ]
          },
          "environment": {
            "type": "object",
            "properties": {
              "runtime": {
                "type": "object",
                "properties": {
                  "kind": {
                    "const": "oci"
                  }
                },
                "required": [
                  "kind"
                ]
              }
            },
            "required": [
              "runtime"
            ]
          }
        },
        "required": [
          "status",
          "environment"
        ]
      },
      "then": {
        "properties": {
          "environment": {
            "type": "object",
            "properties": {
              "runtime": {
                "type": "object",
                "properties": {
                  "image_digest": true
                },
                "required": [
                  "image_digest"
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "kind": {
              "const": "directory"
            },
            "path": {
              "$ref": "common.schema.json#/$defs/relativePath"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "archive_digest"
          ],
          "properties": {
            "kind": {
              "const": "archive"
            },
            "path": {
              "$ref": "common.schema.json#/$defs/relativePath"
            },
            "uri": {
              "type": "string",
              "format": "uri"
            },
            "archive_digest": {
              "$ref": "common.schema.json#/$defs/sha256"
            }
          },
          "anyOf": [
            {
              "properties": {
                "path": true
              },
              "required": [
                "path"
              ]
            },
            {
              "properties": {
                "uri": true
              },
              "required": [
                "uri"
              ]
            }
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "repository",
            "revision"
          ],
          "properties": {
            "kind": {
              "const": "git"
            },
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "revision": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}(?:[a-f0-9]{24})?$"
            },
            "patches": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "path",
                  "digest"
                ],
                "properties": {
                  "path": {
                    "$ref": "common.schema.json#/$defs/relativePath"
                  },
                  "digest": {
                    "$ref": "common.schema.json#/$defs/sha256"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "problemState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "digest_algorithm"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/source"
        },
        "materialize_command": {
          "$ref": "common.schema.json#/$defs/command"
        },
        "digest_algorithm": {
          "const": "tree-sha256-v1"
        },
        "expected_tree_digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "runtime": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "image",
            "platform"
          ],
          "properties": {
            "kind": {
              "const": "oci"
            },
            "image": {
              "type": "string",
              "minLength": 1
            },
            "image_digest": {
              "$ref": "common.schema.json#/$defs/sha256"
            },
            "platform": {
              "type": "string",
              "pattern": "^linux/(amd64|arm64)$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "host"
            },
            "platform": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "network",
        "workspace_directory",
        "setup_commands",
        "variables",
        "secret_names"
      ],
      "properties": {
        "runtime": {
          "$ref": "#/$defs/runtime"
        },
        "network": {
          "$ref": "common.schema.json#/$defs/networkPolicy"
        },
        "workspace_directory": {
          "type": "string",
          "pattern": "^/"
        },
        "setup_commands": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/command"
          }
        },
        "variables": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Z_][A-Z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "secret_names": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z_][A-Z0-9_]*$"
          }
        }
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "command",
        "timeout_seconds",
        "result_file"
      ],
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "command": {
          "$ref": "common.schema.json#/$defs/command"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "result_file": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "digest": {
          "$ref": "common.schema.json#/$defs/treeDigest"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "weight",
        "required",
        "agent_visible"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required": {
          "type": "boolean"
        },
        "agent_visible": {
          "type": "boolean"
        }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks",
        "pass_threshold",
        "require_agent_completion"
      ],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "pass_threshold": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "require_agent_completion": {
          "type": "boolean"
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_path",
        "evidence_digest",
        "reference_passes",
        "untouched_fails",
        "partial_solution_checked",
        "deterministic_runs"
      ],
      "properties": {
        "evidence_path": {
          "$ref": "common.schema.json#/$defs/relativePath"
        },
        "evidence_digest": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "reference_passes": {
          "const": true
        },
        "untouched_fails": {
          "const": true
        },
        "partial_solution_checked": {
          "const": true
        },
        "deterministic_runs": {
          "type": "integer",
          "minimum": 3
        }
      }
    }
  }
}
