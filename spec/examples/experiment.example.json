        "display_label": "medium",
        "native_value": "medium"
      },
      "limits": {
        "wall_time_seconds": {
          "value": 1200,
          "enforcement": "hard"
        },
        "total_tokens": {
          "value": 200000,
          "enforcement": "observe-only"
        }
      }
    },
    {
      "id": "codex-high",
      "harness": {
        "family": "codex",
        "interface": "cli-exec",
        "adapter_id": "codex-cli",
        "adapter_version": "0.1.0",
        "runtime_version": "0.145.0-alpha.11",
        "config": {
          "sandbox": "workspace-write",
          "network": "task-policy",
          "user_config": "ignored"
        }
      },
      "model": {
        "provider": "openai",
        "requested_id": "gpt-5.6-sol"
      },
      "effort": {
        "display_label": "high",
        "native_value": "high"
      },
      "limits": {
        "wall_time_seconds": {
          "value": 1200,
          "enforcement": "hard"
        },
        "total_tokens": {
          "value": 200000,
          "enforcement": "observe-only"
        }
      }
